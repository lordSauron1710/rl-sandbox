# Shared local development config for `make dev` / `scripts/dev.sh`

# Backend bind address + port
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend bind address + port
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000

# Frontend -> backend API base URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Backend run artifact directory.
# Relative paths are resolved from repository root by scripts/dev.sh.
RLV_RUNS_DIR=backend/runs

# Optional explicit CORS origins for backend.
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
