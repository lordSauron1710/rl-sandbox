# Shared local development config for `make dev` / `scripts/dev.sh`
#
# For the full no-monthly-bill deployment path, use
# `deploy/selfhosted/backend.env.example` on the backend machine instead.
# Set `RLV_ACCESS_TOKEN` there for the hosted Vercel + self-hosted backend flow.
# Optional Vercel CLI auth token for deployment helper scripts.
# VERCEL_TOKEN=
# Optional Vercel project name/id for non-interactive linking.
# VERCEL_PROJECT=your-project-name
# Optional Vercel team/account scope for deployment helper scripts.
# VERCEL_SCOPE=your-team-or-username
# Optional Vercel production deploy hook fallback when CLI auth is unavailable.
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
# Optional override for the frontend project dir used by Vercel helper scripts.
# VERCEL_PROJECT_DIR=frontend
# Optional override for the self-hosted backend env file used by deployment helpers.
# SELFHOSTED_ENV_FILE=deploy/selfhosted/backend.env

# App environment (`development` or `production`).
APP_ENV=development

# Backend bind address + port
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend bind address + port
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000

# Frontend -> backend API base URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Backend run artifact directory.
# Relative paths are resolved from repository root by scripts/dev.sh.
RLV_RUNS_DIR=backend/runs

# Backend SQLite database path.
# Relative paths are resolved from repository root by scripts/dev.sh.
RLV_DB_PATH=backend/data/rl_visualizer.db

# Optional explicit CORS origins for backend.
# CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Optional single frontend origin appended to CORS origins.
# FRONTEND_URL=https://your-app.vercel.app
# Optional regex for dynamic preview origins (e.g. Vercel previews).
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
# Optional trusted host allowlist for backend HTTP requests.
# TRUSTED_HOSTS=localhost,127.0.0.1,api.example.com
# Production only: set to `private` only when the backend stays behind a trusted private network boundary.
# RLV_DEPLOYMENT_BOUNDARY=private
# Disable interactive API docs in production by default; set to true only for private/admin deployments.
# ENABLE_API_DOCS=false
